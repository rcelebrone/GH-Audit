# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NUNCA deve ser commitado.

# Token de acesso pessoal do GitHub
# Permissões necessárias: repo, read:user, read:org
GITHUB_TOKEN=ghp_seu_token_aqui

# Usuários a auditar, separados por vírgula.
# Ignorado quando SQUAD_* estiver configurado.
GITHUB_USERS=user1,user2,user3

# Organizações a filtrar, separadas por vírgula.
# Deixe em branco para auditar todas as orgs do usuário.
GITHUB_ORGS=MinhaOrg

# Squads: defina uma variável SQUAD_<NOME> por equipe.
# Quando configurado, os usuários são extraídos das squads automaticamente
# e o relatório exibe uma tabela separada por squad.
# SQUAD_BACKEND=alice,bob,carol
# SQUAD_MOBILE=dave,eve
# SQUAD_FRONTEND=frank,grace
